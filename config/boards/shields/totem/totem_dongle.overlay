#include "totem.dtsi"

/* Disable the physical matrix scanner on the dongle so it doesn't fight the Prospector display pins */
/ {
    chosen {
        /delete-property/ zmk,kscan;
    };
};

&kscan0 {
    status = "disabled";
};
